#, no-wrap
msgid "DESCRIPTION"
msgstr ""

#. type: Plain text
#: makebread.1:11
msgid ""
"B<makebread> is a GTK4/Adwaita recipe manager for bread baking. It provides "
"a searchable database of bread recipes with ingredients, instructions, and "
"timers."
msgstr ""

#. type: Plain text
#: makebread.1:14
msgid ""
"Features include recipe favorites, CSV/JSON export, Swedish translation "
"support, and keyboard shortcuts."
msgstr ""

